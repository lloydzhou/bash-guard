#!/bin/sh
# 独立二进制的最小失败关闭适配器。
set -eu

emit_deny() {
  printf '%s\n' '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"Bash Guard 启动器无法执行安全检查，已按失败关闭处理"}}'
}

if [ -n "${BASH_GUARD_BINARY:-}" ]; then
  guard=$BASH_GUARD_BINARY
else
  guard=$(command -v bash-guard 2>/dev/null || true)
fi

if [ -z "$guard" ] || [ ! -x "$guard" ]; then
  emit_deny
  exit 0
fi

tmp=$(mktemp "${TMPDIR:-/tmp}/bash-guard-hook.XXXXXX") || {
  emit_deny
  exit 0
}
trap 'rm -f "$tmp"' EXIT HUP INT TERM

if ! "$guard" claude hook >"$tmp"; then
  emit_deny
  exit 0
fi
cat "$tmp"
